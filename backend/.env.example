# ============================================================
# GymOS India - Backend Environment Variables
# ============================================================

# Server
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://gymos_user:gymos_pass_2024@localhost:5432/gymos_india

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_gymos_2024

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_change_in_production_min_32_chars

# Razorpay (Payment Gateway)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# WhatsApp Business API (Meta)
WHATSAPP_API_TOKEN=EAAxxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=1234567890123456
WHATSAPP_BUSINESS_ID=1234567890123456
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token

# SMS - MSG91
MSG91_API_KEY=xxxxxxxxxxxxxxxxxxxxxx
MSG91_TEMPLATE_ID=your_otp_template_id
MSG91_SENDER_ID=GYMOS

# AWS S3 (File Storage)
AWS_ACCESS_KEY_ID=AKIA_xxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
AWS_S3_BUCKET=gymos-india-uploads
AWS_REGION=ap-south-1

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@gymos.in
SMTP_PASS=your_smtp_password
SMTP_FROM=GymOS India <noreply@gymos.in>

# App
APP_NAME=GymOS India
APP_URL=https://gymos.in
SUPPORT_PHONE=+91-XXXXX-XXXXX
