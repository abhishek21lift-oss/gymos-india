# ============================================================
# GymOS India - Backend Environment Variables
# ============================================================
# Copy this file to .env and replace with your actual values.
# NEVER commit .env to version control.

# Server
NODE_ENV=production
PORT=10000
FRONTEND_URL=https://your-frontend-domain.vercel.app

# Database (replace with your actual Supabase/PostgreSQL URL)
DATABASE_URL=postgresql://user:password@host:5432/postgres

# Redis (optional - for Bull queues)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT (generate with: openssl rand -hex 64)
JWT_SECRET=change_me_to_a_random_64_char_hex_string
JWT_REFRESH_SECRET=change_me_to_another_random_64_char_hex_string

# Razorpay (Payment Gateway)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# WhatsApp Business API (Meta) - optional
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# SMS - MSG91 - optional
MSG91_API_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=GYMOS

# AWS S3 (File Storage) - optional
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=gymos-india-uploads
AWS_REGION=ap-south-1

# Email - optional
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=GymOS India <noreply@gymos.in>

# App
APP_NAME=GymOS India
APP_URL=https://gymos.in
SUPPORT_PHONE=+91-XXXXX-XXXXX
